  "repository": {
    "type": "git",
    "url": "https://github.com/delta-comic/awesome-plugins"
  },
  "type": "module",
  "scripts": {
    "begin": "bun --bun ./src/index.ts",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run validate:data",
    "fmt": "oxfmt --write .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "test": "bun test",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "validate:data": "bun begin validate"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "commander": "^15.0.0",
    "jszip": "^3.10.1",
    "octokit": "^5.0.5",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "typescript": "^7.0.2"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.14"
}