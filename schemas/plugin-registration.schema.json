{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://delta-comic.github.io/awesome-plugins/schemas/plugin-registration.schema.json",
  "title": "Plugin registration",
  "$defs": {
    "download": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": { "const": "github" },
            "repository": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" }
          },
          "required": ["type", "repository"]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": { "const": "url" },
            "url": { "type": "string", "format": "uri", "pattern": "^https?://" }
          },
          "required": ["type", "url"]
        }
      ]
    }
  },
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{0,63}$" },
    "authors": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$" }
    },
    "download": { "$ref": "#/$defs/download" }
  },
  "required": ["schemaVersion", "id", "authors", "download"]
}