{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://delta-comic.github.io/awesome-plugins/schemas/plugin-listing.schema.json",
  "title": "Plugin marketplace listing",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{0,63}$" },
    "authors": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$" }
    },
    "download": {
      "$ref": "https://delta-comic.github.io/awesome-plugins/schemas/plugin-registration.schema.json#/$defs/download"
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "owner": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "defaultBranch": { "type": "string", "minLength": 1 },
        "lastCommitAt": { "type": "string", "format": "date-time" },
        "readmeUrl": { "type": "string", "format": "uri" }
      },
      "required": ["owner", "name", "url", "defaultBranch", "lastCommitAt"]
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "version": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "publishedAt": { "type": "string", "format": "date-time" },
        "manifestUrl": {
          "type": "string",
          "format": "uri",
          "description": "Direct manifest URL, or the release asset URL when manifestPath is present"
        },
        "manifestPath": {
          "type": "string",
          "pattern": "(^|/)manifest\\.json$",
          "description": "Path to manifest.json inside the release asset referenced by manifestUrl"
        }
      },
      "required": ["version", "url", "publishedAt"],
      "dependentRequired": { "manifestPath": ["manifestUrl"] }
    }
  },
  "required": ["schemaVersion", "id", "authors", "download"]
}